# Security Headers for Tours North - A-Grade Security Rating
# Content Security Policy (CSP) and HSTS for traveler booking data protection

/*
  # Content Security Policy - Strict
  Content-Security-Policy: default-src 'self';
    script-src 'self' 'unsafe-inline' https://cdn.tailwindcss.com https://cdn.jsdelivr.net https://www.googletagmanager.com https://www.google-analytics.com;
    style-src 'self' 'unsafe-inline' https://fonts.googleapis.com https://cdn.tailwindcss.com;
    font-src 'self' https://fonts.gstatic.com;
    img-src 'self' data: https: blob:;
    connect-src 'self' https://www.google-analytics.com https://www.googletagmanager.com;
    frame-src 'none';
    object-src 'none';
    base-uri 'self';
    form-action 'self';
    upgrade-insecure-requests;

  # HTTP Strict Transport Security (HSTS) - Force HTTPS
  Strict-Transport-Security: max-age=31536000; includeSubDomains; preload

  # Security Headers
  X-Frame-Options: DENY
  X-Content-Type-Options: nosniff
  X-XSS-Protection: 1; mode=block
  Referrer-Policy: strict-origin-when-cross-origin
  Permissions-Policy: geolocation=(), microphone=(), camera=()

  # Cache Control for static assets
  Cache-Control: public, max-age=31536000, immutable

# API endpoints - Additional security
/api/*
  Content-Security-Policy: default-src 'none'; frame-ancestors 'none';
  X-Frame-Options: DENY
  X-Content-Type-Options: nosniff

# Partners dashboard - Restricted access
/partners/dashboard.html
  Content-Security-Policy: default-src 'self'; script-src 'self' 'unsafe-inline';
  X-Frame-Options: SAMEORIGIN

# Checkout pages - Enhanced security for booking data
/checkout.html
  Content-Security-Policy: default-src 'self';
    script-src 'self' 'unsafe-inline' https://js.stripe.com https://cdn.tailwindcss.com;
    connect-src 'self' https://api.stripe.com;
  Strict-Transport-Security: max-age=31536000; includeSubDomains; preload

# Admin areas - Maximum security
/admin/*
  Content-Security-Policy: default-src 'none'; script-src 'none'; style-src 'none';
  X-Frame-Options: DENY
  X-Content-Type-Options: nosniff
